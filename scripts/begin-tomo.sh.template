#!/bin/bash
# begin-tomo.sh — Start a Tomo Docker session.
# GENERATED by install-tomo.sh — do not edit manually.
# Re-run install-tomo.sh to regenerate with updated values.
# version: 0.8.0
set -e

# ── Hardcoded values (injected at install time) ──────────

INSTANCE_PATH="{{INSTANCE_PATH}}"
INSTANCE_NAME="{{INSTANCE_NAME}}"
HOME_DIR="{{HOME_DIR}}"
TOMO_REPO_ROOT="{{TOMO_REPO_ROOT}}"
DEV_NOTIFY_PORT="{{DEV_NOTIFY_PORT}}"
IMAGE_NAME="miyo-tomo:latest"

# ── Colors ────────────────────────────────────────────────

if [ -t 1 ]; then
    C_RESET="\033[0m"
    C_BOLD="\033[1m"
    C_DIM="\033[2m"
    C_CYAN="\033[36m"
    C_GREEN="\033[32m"
    C_YELLOW="\033[33m"
    C_RED="\033[31m"
else
    C_RESET="" C_BOLD="" C_DIM="" C_CYAN="" C_GREEN="" C_YELLOW="" C_RED=""
fi

print_step() { printf "\n${C_BOLD}${C_CYAN}▸ %s${C_RESET}\n" "$1"; }
print_ok()   { printf "  ${C_GREEN}✓${C_RESET} %s\n" "$1"; }
print_warn() { printf "  ${C_YELLOW}⚠${C_RESET} %s\n" "$1"; }
print_err()  { printf "  ${C_RED}✗${C_RESET} %s\n" "$1" >&2; }

# ── CLI Flags ─────────────────────────────────────────────

FORCE_REBUILD=false
BASH_MODE=false
YOLO_MODE=false
AUTO_MODE=false
SHOW_HELP=false
HAS_MODE_FLAG=false

while [ $# -gt 0 ]; do
    case "$1" in
        --rebuild-image) FORCE_REBUILD=true; shift ;;
        --bash)          BASH_MODE=true;  HAS_MODE_FLAG=true; shift ;;
        --yolo)          YOLO_MODE=true;  HAS_MODE_FLAG=true; shift ;;
        --auto)          AUTO_MODE=true;  HAS_MODE_FLAG=true; shift ;;
        --help|-h)       SHOW_HELP=true;     shift ;;
        *)
            print_err "Unknown option: $1"
            echo "Run with --help for usage." >&2
            exit 1
            ;;
    esac
done

# ── Default mode from tomo-install.json ──────────────────
# If no mode flag was passed on the CLI, check for a configured default.
# User sets "defaultMode" in tomo-install.json: "default", "auto", "yolo", or "bash".

if [ "$HAS_MODE_FLAG" = "false" ] && [ "$SHOW_HELP" = "false" ] && command -v jq > /dev/null 2>&1; then
    CONFIG_FILE="$TOMO_REPO_ROOT/tomo-install.json"
    if [ -f "$CONFIG_FILE" ]; then
        DEFAULT_MODE="$(jq -r '.defaultMode // "default"' "$CONFIG_FILE")"
        case "$DEFAULT_MODE" in
            yolo) YOLO_MODE=true ;;
            auto) AUTO_MODE=true ;;
            bash) BASH_MODE=true ;;
            default|"") ;; # no-op, standard interactive mode
            *)
                print_warn "Unknown defaultMode in tomo-install.json: '$DEFAULT_MODE' — ignoring"
                ;;
        esac
    fi
fi

if [ "$SHOW_HELP" = "true" ]; then
    cat <<HELPEOF
Usage: bash begin-tomo.sh [OPTIONS]

Start a Tomo Docker session for instance: ${INSTANCE_NAME}

Options:
  --rebuild-image   Force rebuild of the Docker image before launch
  --bash            Launch a bash shell instead of Claude Code.
                    Useful for debugging the container environment.
  --auto            Auto mode — AI classifier approves safe actions
                    automatically. You still get prompted for risky
                    operations. Recommended for interactive sessions.
  --yolo            Skip ALL permission prompts (bypass permissions).
                    Tomo runs in a sandboxed Docker container with
                    no direct vault access — all writes go through
                    Kado MCP. Use for unattended sessions.
  --help, -h        Show this help

Default mode:
  Set "defaultMode" in tomo-install.json to change what happens
  when you run begin-tomo.sh without flags:
    "default"  — standard interactive (permission prompts)
    "auto"     — AI classifier approves safe actions
    "yolo"     — skip all permission prompts
    "bash"     — launch shell instead of Claude

Paths (baked in at install time):
  Instance:  ${INSTANCE_PATH}
  Home:      ${HOME_DIR}
  Tomo src:  ${TOMO_REPO_ROOT}

To refresh these values, re-run: bash ${TOMO_REPO_ROOT}/scripts/install-tomo.sh
HELPEOF
    exit 0
fi

# ── Splash screen ─────────────────────────────────────────

show_splash() {
    local logo_file="$TOMO_REPO_ROOT/assets/tomo-small-logo-50-2.txt"
    local version="unknown"
    local version_file="$TOMO_REPO_ROOT/tomo/dot_claude/rules/project-context.md"
    if [ -f "$version_file" ]; then
        version="$(grep -m1 '^# version:' "$version_file" 2>/dev/null \
            | sed 's/^# version: *//' || echo 'unknown')"
    fi

    [ -f "$logo_file" ] || return 0

    local C_MAGENTA_BOLD="\033[1;35m"
    local C_DIM="\033[2m"
    local C_CYAN_SPLASH="\033[36m"
    local C_RESET_SPLASH="\033[0m"
    if [ ! -t 1 ]; then
        C_MAGENTA_BOLD="" C_DIM="" C_CYAN_SPLASH="" C_RESET_SPLASH=""
    fi

    printf "\n"
    awk '
        { lines[NR] = $0 }
        END {
            first = 1
            while (first <= NR && lines[first] ~ /^[[:space:]]*$/) first++
            last = NR
            while (last >= first && lines[last] ~ /^[[:space:]]*$/) last--
            for (i = first; i <= last; i++) print lines[i]
        }
    ' "$logo_file"
    printf "\n"
    printf "               %b友  MiYo Tomo%b %bv%s%b\n" \
        "$C_MAGENTA_BOLD" "$C_RESET_SPLASH" "$C_DIM" "$version" "$C_RESET_SPLASH"
    printf "           %bPersonal Knowledge Companion%b\n" "$C_CYAN_SPLASH" "$C_RESET_SPLASH"
    printf "             AI handles processes,\n"
    printf "                 not decisions\n"
}

show_splash

# ── Pre-flight ────────────────────────────────────────────

if ! docker info > /dev/null 2>&1; then
    print_err "Docker is not running. Start OrbStack or Docker Desktop."
    exit 1
fi

if [ ! -d "$INSTANCE_PATH" ]; then
    print_err "Instance directory not found: $INSTANCE_PATH"
    print_err "Re-run: bash ${TOMO_REPO_ROOT}/scripts/install-tomo.sh"
    exit 1
fi

if [ ! -d "$HOME_DIR" ]; then
    print_err "Home directory not found: $HOME_DIR"
    print_err "Re-run: bash ${TOMO_REPO_ROOT}/scripts/install-tomo.sh"
    exit 1
fi

# ── Version check (optional, skips if tomo source is gone) ──

SOURCE_VERSION_FILE="$TOMO_REPO_ROOT/tomo/dot_claude/rules/project-context.md"
CONFIG_FILE="$TOMO_REPO_ROOT/tomo-install.json"

# Resolve INSTANCE_VERSION unconditionally so we can export it into the
# container. Falls back to "unknown" when jq or tomo-install.json is missing.
INSTANCE_VERSION="unknown"
if [ -f "$CONFIG_FILE" ] && command -v jq > /dev/null 2>&1; then
    INSTANCE_VERSION="$(jq -r '.tomoVersion // "unknown"' "$CONFIG_FILE")"
fi

if [ -f "$SOURCE_VERSION_FILE" ] && [ -f "$CONFIG_FILE" ] && command -v jq > /dev/null 2>&1; then
    SOURCE_VERSION="$(grep -m1 '^# version:' "$SOURCE_VERSION_FILE" 2>/dev/null | sed 's/^# version: *//' || echo 'unknown')"
    if [ "$INSTANCE_VERSION" != "$SOURCE_VERSION" ] && [ "$SOURCE_VERSION" != "unknown" ]; then
        echo ""
        print_warn "Instance version (${INSTANCE_VERSION}) differs from source (${SOURCE_VERSION})"
        printf "  Run: ${C_CYAN}bash %s/scripts/update-tomo.sh${C_RESET}\n" "$TOMO_REPO_ROOT"
        echo ""
        read -rp "  Continue anyway? [y/N] " CONTINUE
        case "$CONTINUE" in
            [yY]*) ;;
            *) exit 0 ;;
        esac
    fi
fi

# ── dev-notify-bridge lifecycle ───────────────────────────

print_step "Checking dev-notify-bridge"

case "$(uname -s)" in
    Darwin)
        if ! command -v terminal-notifier > /dev/null 2>&1; then
            print_warn "terminal-notifier not installed — desktop notifications may not appear"
            echo "  Install with: brew install terminal-notifier"
        fi
        ;;
    Linux)
        if ! command -v notify-send > /dev/null 2>&1; then
            print_warn "notify-send not found — desktop notifications may not appear"
            echo "  Install with: sudo apt install libnotify-bin"
        fi
        ;;
esac

if ! curl -s "http://localhost:${DEV_NOTIFY_PORT}/health" > /dev/null 2>&1; then
    if command -v npx > /dev/null 2>&1; then
        npx dev-notify-bridge --port "$DEV_NOTIFY_PORT" &
        sleep 1
        print_ok "dev-notify-bridge started on port $DEV_NOTIFY_PORT"
    else
        print_warn "npx not found — dev-notify-bridge not started"
    fi
else
    print_ok "dev-notify-bridge already running on port $DEV_NOTIFY_PORT"
fi

# ── Voice transcription build state (XDD 009) ────────────
# The Dockerfile accepts VOICE_ENABLED as a build arg. We label the built
# image so subsequent starts can detect when the user's choice drifted
# (e.g. toggled voice via update-tomo.sh) and trigger an automatic rebuild.
#
# Read from the INSTANCE mirror ($INSTANCE_PATH/voice/config.json) rather
# than tomo-install.json — the mirror is what runtime agents actually see
# inside the container. If the two disagree (e.g. stale mirror after a
# manual edit), this makes the banner and build-arg reflect container
# reality, and a re-run of install/update-tomo will re-sync both.

VOICE_ENABLED="0"
VOICE_MODEL_RUNTIME=""
VOICE_LANG_RUNTIME="auto"
VOICE_CONFIG_MIRROR="$INSTANCE_PATH/voice/config.json"
if [ -f "$VOICE_CONFIG_MIRROR" ] && command -v jq > /dev/null 2>&1; then
    if [ "$(jq -r '.enabled // false' "$VOICE_CONFIG_MIRROR")" = "true" ]; then
        VOICE_ENABLED="1"
    fi
    VOICE_MODEL_RUNTIME="$(jq -r '.model // ""' "$VOICE_CONFIG_MIRROR")"
    VOICE_LANG_RUNTIME="$(jq -r '.language // "auto"' "$VOICE_CONFIG_MIRROR")"
fi

# ── Docker image ──────────────────────────────────────────

BUILD_CONTEXT="$TOMO_REPO_ROOT/docker"

build_image() {
    if [ ! -f "$BUILD_CONTEXT/Dockerfile" ]; then
        print_err "Dockerfile not found: $BUILD_CONTEXT/Dockerfile"
        print_err "Tomo source repo appears broken or moved."
        exit 1
    fi
    docker build \
        --build-arg "VOICE_ENABLED=$VOICE_ENABLED" \
        --label "tomo.voice_enabled=$VOICE_ENABLED" \
        -t "$IMAGE_NAME" "$BUILD_CONTEXT"
    print_ok "Image built: $IMAGE_NAME (voice_enabled=$VOICE_ENABLED)"
}

# Detect voice-toggle drift: if the existing image was built with a
# different VOICE_ENABLED value than the current config, rebuild.
image_voice_drift() {
    if ! docker image inspect "$IMAGE_NAME" > /dev/null 2>&1; then
        return 1  # no image — caller handles first-time build
    fi
    local built_with
    built_with="$(docker image inspect --format '{{ index .Config.Labels "tomo.voice_enabled" }}' "$IMAGE_NAME" 2>/dev/null || echo "")"
    [ "$built_with" != "$VOICE_ENABLED" ]
}

if [ "$FORCE_REBUILD" = "true" ]; then
    print_step "Rebuilding Docker image (forced)"
    build_image
elif ! docker image inspect "$IMAGE_NAME" > /dev/null 2>&1; then
    print_step "Building Docker image (first time)"
    build_image
elif image_voice_drift; then
    print_step "Rebuilding Docker image (voice setting changed)"
    build_image
else
    print_ok "Image exists: $IMAGE_NAME (voice_enabled=$VOICE_ENABLED)"
fi

# ── Auth ──────────────────────────────────────────────────
# Port 10000 is always exposed for OAuth callback — it's localhost-only
# and avoids needing to restart the container when credentials expire.

AUTH_FLAGS=(-p 10000:10000)

if [ ! -f "$HOME_DIR/.claude/.credentials.json" ]; then
    print_warn "No credentials found — run 'claude login' inside the container"
else
    print_ok "Auth state found (.credentials.json)"
fi

# ── Stop any existing container with the same name ───────

CONTAINER_NAME="tomo-${INSTANCE_NAME}"

if docker ps -q -f "name=^${CONTAINER_NAME}$" 2>/dev/null | grep -q .; then
    docker stop "$CONTAINER_NAME" > /dev/null 2>&1 || true
fi
if docker ps -aq -f "name=^${CONTAINER_NAME}$" 2>/dev/null | grep -q .; then
    docker rm "$CONTAINER_NAME" > /dev/null 2>&1 || true
fi

# ── First-run detection ──────────────────────────────────
# The discovery cache is created by /explore-vault. If it's missing,
# this is either a fresh install or the user hasn't explored yet.

# Check both canonical (config/) and legacy (.claude/) paths
DISCOVERY_CACHE="$INSTANCE_PATH/config/discovery-cache.yaml"
DISCOVERY_CACHE_ALT="$INSTANCE_PATH/.claude/discovery-cache.yaml"
if [ ! -f "$DISCOVERY_CACHE" ] && [ ! -f "$DISCOVERY_CACHE_ALT" ] && [ "$BASH_MODE" != "true" ]; then
    echo ""
    printf "${C_CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${C_RESET}\n"
    printf "  ${C_BOLD}First run detected — welcome to Tomo!${C_RESET}\n"
    echo ""
    printf "  Start with a single command:\n"
    echo ""
    printf "    ${C_BOLD}/tomo-setup${C_RESET}     — vault discovery + user rules + templates\n"
    printf "                      (recommended — covers everything you need)\n"
    echo ""
    printf "  After setup:\n"
    echo ""
    printf "    ${C_BOLD}/inbox${C_RESET}          — process items in your inbox\n"
    printf "    ${C_BOLD}/tomo-help${C_RESET}      — context-aware help anytime\n"
    echo ""
    printf "  ${C_DIM}Power users: /explore-vault standalone, /tomo-setup check for status${C_RESET}\n"
    printf "${C_CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${C_RESET}\n"
fi

# ── Launch ────────────────────────────────────────────────

print_step "Starting Tomo container: $CONTAINER_NAME"
printf "  Instance: ${C_CYAN}%s${C_RESET}\n" "$INSTANCE_PATH"
printf "  Home:     ${C_CYAN}%s${C_RESET}\n" "$HOME_DIR"

# Voice status — one line, color-coded. Reads the instance mirror
# (the source runtime agents actually consume).
if [ "$VOICE_ENABLED" = "1" ]; then
    VOICE_MODEL_DIR="$INSTANCE_PATH/voice/models/faster-whisper-${VOICE_MODEL_RUNTIME}"
    if [ -f "$VOICE_MODEL_DIR/.download-complete" ]; then
        printf "  Voice:    ${C_GREEN}ENABLED${C_RESET} — model=%s, lang=%s\n" \
            "${VOICE_MODEL_RUNTIME:-?}" "${VOICE_LANG_RUNTIME}"
    else
        printf "  Voice:    ${C_YELLOW}ENABLED (model missing — re-run install-tomo.sh)${C_RESET} — expected=%s\n" \
            "$VOICE_MODEL_DIR"
    fi
else
    printf "  Voice:    ${C_DIM}disabled${C_RESET}\n"
fi

if [ "$BASH_MODE" = "true" ]; then
    CMD=(bash)
    print_warn "Bash mode — launching shell instead of claude"
else
    CMD=(claude)
    if [ "$YOLO_MODE" = "true" ]; then
        CMD+=(--dangerously-skip-permissions)
        print_warn "YOLO mode — all permission prompts bypassed"
    elif [ "$AUTO_MODE" = "true" ]; then
        CMD+=(--permission-mode auto)
        print_ok "Auto mode — AI classifier approves safe actions"
    fi
fi

VOICE_MOUNT_FLAGS=()
if [ "$VOICE_ENABLED" = "1" ] && [ -d "$INSTANCE_PATH/voice/models" ]; then
    VOICE_MOUNT_FLAGS+=(-v "$INSTANCE_PATH/voice:/tomo/voice:ro")
    # Mount confirmation is silent — the "Voice: ENABLED" line above
    # already announced runtime state to the user.
fi

docker run -it --rm \
    --name "$CONTAINER_NAME" \
    --hostname tomo \
    -w "$INSTANCE_PATH" \
    "${AUTH_FLAGS[@]}" \
    -e "TERM=xterm-256color" \
    -e "TOMO_INSTANCE_DIR=$INSTANCE_PATH" \
    -e "TOMO_VERSION=$INSTANCE_VERSION" \
    -e "DEV_NOTIFY_PORT=$DEV_NOTIFY_PORT" \
    -v "$INSTANCE_PATH:$INSTANCE_PATH" \
    -v "$HOME_DIR:/home/coder" \
    "${VOICE_MOUNT_FLAGS[@]}" \
    "$IMAGE_NAME" \
    "${CMD[@]}"
