# Tomo instance (created by install-tomo.sh, name may differ)
# The actual entry is added dynamically by install-tomo.sh
tomo-instance/

# Tomo Docker home (Claude Code home directory for container)
tomo-home/

# Tomo backup archives (sibling to tomo-instance/, created by backup-tomo.sh)
tomo-backups/

# Install config (contains local paths and tokens)
tomo-install.json

# Generated launcher (rendered by install-tomo.sh from scripts/begin-tomo.sh.template)
begin-tomo.sh

# Claude Code session files
.claude.json
.credentials.json

# macOS
.DS_Store

# Node
node_modules/

# Misc
*.backup-*
__pycache__/
