{
  "permissions": {
    "allow": [
      "mcp__kado__*",
      "Bash(python3 scripts/*.py*)",
      "Bash(python3 scripts/lib/*.py*)",
      "Bash(python3:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(date:*)",
      "Bash(mkdir:*)",
      "Bash(echo:*)",
      "Bash(claude:*)",
      "Skill(*)",
      "Read(*)",
      "Edit(config/*)",
      "Write(config/*)",
      "Edit(.claude/*)",
      "Write(.claude/*)"
