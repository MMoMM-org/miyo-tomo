{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://miyo.tomo/schemas/instructions.schema.json",
  "title": "Tomo Instructions",
  "description": "Canonical, machine-readable instruction set produced by instruction-render.py. Consumed by Tomo Hashi (Obsidian plugin) for execution and rendered to a human-readable markdown view.",
  "type": "object",
  "required": ["schema_version", "type", "generated", "profile", "actions"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "1"},
    "type": {"const": "tomo-instructions"},
    "source_suggestions": {
      "type": ["string", "null"],
      "description": "Filename (vault-relative or stem) of the suggestions doc this set was derived from."
    },
    "generated": {
      "type": "string",
      "description": "ISO-8601 UTC timestamp of generation."
    },
    "profile": {
      "type": ["string", "null"],
      "description": "Active profile name from vault-config.yaml."
    },
    "tomo_version": {
      "type": ["string", "null"],
      "description": "Tomo version that produced this file."
    },
    "action_count": {"type": "integer", "minimum": 0},
    "actions": {
      "type": "array",
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/move_note"},
          {"$ref": "#/$defs/link_to_moc"},
          {"$ref": "#/$defs/update_tracker"},
          {"$ref": "#/$defs/update_log_entry"},
          {"$ref": "#/$defs/update_log_link"},
          {"$ref": "#/$defs/create_moc"},
          {"$ref": "#/$defs/delete_source"},
          {"$ref": "#/$defs/skip"}
        ]
      }
    }
  },
  "$defs": {
    "action_id": {
      "type": "string",
      "pattern": "^I[0-9]{2,}$",
      "description": "Monotonic action identifier (I01, I02, …). Unique within the instruction set."
    },
    "move_note": {
      "type": "object",
      "required": ["id", "action", "source_path", "rendered_file", "title", "destination"],
      "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/action_id"},
        "action": {"const": "move_note"},
        "source_path": {"type": ["string", "null"], "description": "Vault-relative path of the source inbox note (may be null for proposed MOCs)."},
        "rendered_file": {"type": "string", "description": "Filename (inside inbox) of the rendered note that Tomo wrote."},
        "title": {"type": "string"},
        "destination": {"type": "string", "description": "Vault-relative destination folder (trailing slash)."},
        "parent_mocs": {"type": "array", "items": {"type": "string"}},
        "tags": {"type": "array", "items": {"type": "string"}},
        "delete_source": {"type": "boolean", "description": "True when the original source should be removed after the move (i.e. rendered replaces it)."}
      }
    },
    "link_to_moc": {
      "type": "object",
      "required": ["id", "action", "target_moc", "line_to_add"],
      "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/action_id"},
        "action": {"const": "link_to_moc"},
        "target_moc": {"type": "string", "description": "MOC stem (no path, no .md)."},
        "target_moc_path": {"type": ["string", "null"], "description": "Resolved vault-relative path of the MOC, if known."},
        "section_name": {"type": ["string", "null"], "description": "Raw section hint from the suggestion (callout type or heading)."},
        "line_to_add": {"type": "string", "description": "Bullet line to insert under the target section."},
        "source_note_title": {"type": ["string", "null"]}
      }
    },
    "update_tracker": {
      "type": "object",
      "required": ["id", "action", "daily_note_path", "date", "field", "value", "syntax"],
      "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/action_id"},
        "action": {"const": "update_tracker"},
        "daily_note_path": {"type": "string"},
        "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "field": {"type": "string"},
        "value": {"type": ["string", "number", "boolean"]},
        "syntax": {"type": "string", "enum": ["inline_field", "callout_body", "checkbox"]},
        "section": {"type": ["string", "null"]},
        "source_stem": {"type": ["string", "null"]},
        "reason": {"type": ["string", "null"]}
      }
    },
    "update_log_entry": {
      "type": "object",
      "required": ["id", "action", "daily_note_path", "date", "section", "position", "content"],
      "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/action_id"},
        "action": {"const": "update_log_entry"},
        "daily_note_path": {"type": "string"},
        "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "section": {"type": "string", "description": "Daily log heading (e.g. 'Daily Log'), without leading #."},
        "heading_level": {"type": "integer", "minimum": 1, "maximum": 6},
        "position": {"type": "string", "enum": ["after_last_line", "before_first_line", "at_time"]},
        "time": {"type": ["string", "null"], "pattern": "^[0-9]{2}:[0-9]{2}$"},
        "content": {"type": "string"},
        "source_stem": {"type": ["string", "null"]},
        "reason": {"type": ["string", "null"]}
      }
    },
    "update_log_link": {
      "type": "object",
      "required": ["id", "action", "daily_note_path", "date", "section", "position", "target_stem"],
      "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/action_id"},
        "action": {"const": "update_log_link"},
        "daily_note_path": {"type": "string"},
        "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "section": {"type": "string"},
        "heading_level": {"type": "integer", "minimum": 1, "maximum": 6},
        "position": {"type": "string", "enum": ["after_last_line", "before_first_line", "at_time"]},
        "time": {"type": ["string", "null"], "pattern": "^[0-9]{2}:[0-9]{2}$"},
        "target_stem": {"type": "string"},
        "reason": {"type": ["string", "null"]}
      }
    },
    "create_moc": {
      "type": "object",
      "required": ["id", "action", "title", "destination"],
      "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/action_id"},
        "action": {"const": "create_moc"},
        "title": {"type": "string"},
        "destination": {"type": "string"},
        "parent_moc": {"type": ["string", "null"]},
        "template": {"type": ["string", "null"]},
        "rendered_file": {"type": ["string", "null"], "description": "Rendered filename if a template was available; null for instruction-only."},
        "tags": {"type": "array", "items": {"type": "string"}},
        "supporting_items": {"type": ["string", "null"]}
      }
    },
    "delete_source": {
      "type": "object",
      "required": ["id", "action", "source_path", "reason"],
      "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/action_id"},
        "action": {"const": "delete_source"},
        "source_path": {"type": "string"},
        "reason": {"type": "string"}
      }
    },
    "skip": {
      "type": "object",
      "required": ["id", "action", "source_path"],
      "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/action_id"},
        "action": {"const": "skip"},
        "source_path": {"type": ["string", "null"]},
        "reason": {"type": ["string", "null"]}
      }
    }
  }
}
