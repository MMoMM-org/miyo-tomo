{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://miyo.tomo/schemas/shared-ctx.schema.json",
  "title": "Shared Context",
  "description": "Distilled classifier context shared across all Phase-B subagents in one /inbox run.",
  "type": "object",
  "required": ["schema_version", "run_id", "mocs", "tag_prefixes", "classification_keywords"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "1"},
    "run_id": {"type": "string", "minLength": 1},
    "mocs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "title", "topics", "is_classification"],
        "additionalProperties": false,
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "topics": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
          "is_classification": {"type": "boolean"}
        }
      }
    },
    "tag_prefixes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "wildcard", "known_values"],
        "additionalProperties": false,
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "wildcard": {"type": "boolean"},
          "known_values": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "classification_keywords": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {"type": "string"}
      }
    },
    "daily_notes": {
      "type": "object",
      "required": ["enabled", "path_pattern", "date_formats", "tracker_fields"],
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "path_pattern": {"type": "string"},
        "date_formats": {"type": "array", "items": {"type": "string"}},
        "tracker_fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type", "section", "syntax", "keywords", "description", "positive_keywords", "negative_keywords"],
            "additionalProperties": false,
            "properties": {
              "name": {"type": "string"},
              "type": {"type": "string", "enum": ["bool", "rating_1_5", "text", "number", "duration"]},
              "section": {"type": "string"},
              "syntax": {"type": "string", "enum": ["inline_field", "callout_body", "checkbox"]},
              "keywords": {"type": "array", "items": {"type": "string"}},
              "description": {"type": "string"},
              "positive_keywords": {"type": "array", "items": {"type": "string"}},
              "negative_keywords": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "daily_log": {
          "type": "object",
          "required": ["section", "heading_level", "time_extraction", "link_format", "cutoff_days", "auto_create_if_missing"],
          "additionalProperties": false,
          "properties": {
            "section": {"type": "string"},
            "heading_level": {"type": "integer", "minimum": 1, "maximum": 6},
            "time_extraction": {
              "type": "object",
              "required": ["enabled", "sources", "fallback"],
              "additionalProperties": false,
              "properties": {
                "enabled": {"type": "boolean"},
                "sources": {"type": "array", "items": {"type": "string"}},
                "fallback": {"type": "string"}
              }
            },
            "link_format": {"type": "string"},
            "cutoff_days": {"type": "integer", "minimum": 1},
            "auto_create_if_missing": {
              "type": "object",
              "required": ["past", "today", "future"],
              "additionalProperties": false,
              "properties": {
                "past": {"type": "boolean"},
                "today": {"type": "boolean"},
                "future": {"type": "boolean"}
              }
            }
          }
        }
      }
    }
  }
}
