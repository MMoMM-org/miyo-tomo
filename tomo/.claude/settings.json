{
  "permissions": {
    "allow": [
      "mcp__kado__*",
      "Bash(python3 scripts/*.py:*)",
      "Bash(python3 scripts/lib/*.py:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(date:*)",
      "Bash(mkdir:*)",
      "Skill(*)",
      "Read(*)",
      "Edit(config/*)",
      "Write(config/*)",
      "Edit(.claude/*)",
      "Write(.claude/*)"
    ],
    "deny": []
  },
  "statusLine": {
    "type": "command",
    "command": "bash scripts/tomo-statusline.sh"
  },
  "enabledPlugins": {},
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/dev-notify-bridge.sh"
          }
        ]
      }
    ]
  }
}
