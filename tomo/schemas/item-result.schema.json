{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://miyo.tomo/schemas/item-result.schema.json",
  "title": "Item Classifier Result",
  "description": "Output of a Phase-B subagent for a single inbox item. Polymorphic actions[] — an item may produce multiple actions.",
  "type": "object",
  "required": ["schema_version", "stem", "path", "type", "type_confidence", "actions"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "1"},
    "stem": {"type": "string", "minLength": 1},
    "path": {"type": "string", "minLength": 1},
    "type": {"type": "string"},
    "type_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "date_relevance": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["date", "source"],
          "additionalProperties": false,
          "properties": {
            "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
            "source": {"type": "string", "enum": ["filename", "frontmatter", "content"]}
          }
        }
      ]
    },
    "issues": {"type": "array", "items": {"type": "string"}},
    "duration_ms": {"type": "integer", "minimum": 0},
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/create_atomic_note"},
          {"$ref": "#/$defs/update_daily"},
          {"$ref": "#/$defs/link_to_moc"},
          {"$ref": "#/$defs/create_moc"},
          {"$ref": "#/$defs/modify_note"}
        ]
      }
    }
  },
  "$defs": {
    "create_atomic_note": {
      "type": "object",
      "required": ["kind", "suggested_title", "template", "location", "candidate_mocs", "tags_to_add"],
      "additionalProperties": false,
      "properties": {
        "kind": {"const": "create_atomic_note"},
        "suggested_title": {"type": "string", "minLength": 1},
        "template": {"type": "string", "minLength": 1,
                     "description": "Obsidian template file name (e.g. 'Atomic Note.md') or concept key (e.g. 'atomic_note') — whichever the user's templates.mapping exposes."},
        "location": {"type": "string", "minLength": 1,
                     "description": "Target folder path, vault-relative, trailing slash (e.g. 'Atlas/202 Notes/')."},
        "candidate_mocs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "score", "pre_check"],
            "additionalProperties": false,
            "properties": {
              "path": {"type": "string"},
              "score": {"type": "number", "minimum": 0, "maximum": 1},
              "pre_check": {"type": "boolean"}
            }
          }
        },
        "classification": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "required": ["category", "confidence"],
              "additionalProperties": false,
              "properties": {
                "category": {"type": "string"},
                "confidence": {"type": "number", "minimum": 0, "maximum": 1}
              }
            }
          ]
        },
        "needs_new_moc": {"type": "boolean"},
        "proposed_moc_topic": {"type": ["string", "null"]},
        "tags_to_add": {"type": "array", "items": {"type": "string"}},
        "atomic_note_worthiness": {"type": "number", "minimum": 0, "maximum": 1},
        "alternatives": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "reason"],
            "additionalProperties": false,
            "properties": {
              "kind": {"type": "string"},
              "reason": {"type": "string"}
            }
          }
        }
      }
    },
    "update_daily": {
      "type": "object",
      "required": ["kind", "date", "daily_note_path", "updates"],
      "additionalProperties": false,
      "properties": {
        "kind": {"const": "update_daily"},
        "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "daily_note_path": {"type": "string"},
        "updates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              {"$ref": "#/$defs/update_tracker"},
              {"$ref": "#/$defs/update_log_entry"},
              {"$ref": "#/$defs/update_log_link"}
            ]
          }
        }
      }
    },
    "update_tracker": {
      "type": "object",
      "required": ["kind", "field", "value", "syntax", "confidence"],
      "additionalProperties": false,
      "properties": {
        "kind": {"const": "tracker"},
        "field": {"type": "string"},
        "value": {"type": ["string", "number", "boolean"]},
        "syntax": {"type": "string", "enum": ["inline_field", "callout_body", "checkbox"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "reason": {"type": "string"},
        "section": {"type": "string"}
      }
    },
    "update_log_entry": {
      "type": "object",
      "required": ["kind", "content", "reason", "confidence"],
      "additionalProperties": false,
      "properties": {
        "kind": {"const": "log_entry"},
        "content": {"type": "string"},
        "reason": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "time": {
          "oneOf": [
            {"type": "string", "pattern": "^[0-9]{2}:[0-9]{2}$"},
            {"type": "null"}
          ]
        },
        "time_source": {"type": "string"}
      }
    },
    "update_log_link": {
      "type": "object",
      "required": ["kind", "target_stem", "reason", "confidence"],
      "additionalProperties": false,
      "properties": {
        "kind": {"const": "log_link"},
        "target_stem": {"type": "string"},
        "reason": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "time": {
          "oneOf": [
            {"type": "string", "pattern": "^[0-9]{2}:[0-9]{2}$"},
            {"type": "null"}
          ]
        },
        "time_source": {"type": "string"}
      }
    },
    "link_to_moc": {
      "type": "object",
      "required": ["kind", "target_moc", "section_name"],
      "additionalProperties": false,
      "properties": {
        "kind": {"const": "link_to_moc"},
        "target_moc": {"type": "string"},
        "section_name": {"type": "string"}
      }
    },
    "create_moc": {
      "type": "object",
      "required": ["kind", "moc_title", "parent_moc"],
      "additionalProperties": false,
      "properties": {
        "kind": {"const": "create_moc"},
        "moc_title": {"type": "string"},
        "parent_moc": {"type": "string"}
      }
    },
    "modify_note": {
      "type": "object",
      "required": ["kind", "target_path", "diff_description"],
      "additionalProperties": false,
      "properties": {
        "kind": {"const": "modify_note"},
        "target_path": {"type": "string"},
        "diff_description": {"type": "string"}
      }
    }
  }
}
